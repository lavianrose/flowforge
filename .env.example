# FlowForge Environment Configuration
# Copy this file to .env and adjust values for your environment

# Backend Configuration
JWT_SECRET=change-me-in-production-please-use-a-secure-random-string

# Frontend API URL
# For Docker Compose (both containers in Docker):
NEXT_PUBLIC_API_URL=http://backend:3000/api/v1

# For local development (frontend on host, backend in Docker):
# NEXT_PUBLIC_API_URL=http://127.0.0.1:3000/api/v1

# For everything running locally:
# NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
