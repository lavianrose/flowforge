# FlowForge Environment Configuration
# Copy this file to .env and adjust values for your environment

# Backend Configuration
JWT_SECRET=change-me-in-production-please-use-a-secure-random-string

# Frontend API URL
# IMPORTANT: Next.js NEXT_PUBLIC_ variables are build-time variables.
# You must rebuild the Docker image after changing this value.

# For Docker Compose accessed from browser (RECOMMENDED):
# Frontend runs in Docker, backend runs in Docker, accessed from host browser
# Browser cannot resolve Docker service names like 'backend', so use 127.0.0.1
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000/api/v1

# Alternative: For Docker service-to-service communication:
# Only use if frontend is accessed from within Docker network (rare)
# NEXT_PUBLIC_API_URL=http://backend:3000/api/v1

# For local development (frontend runs on host machine):
# NEXT_PUBLIC_API_URL=http://127.0.0.1:3000/api/v1
