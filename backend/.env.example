PORT=3000
ENV=development

POSTGRES_URL=postgres://flowforge:flowforge@localhost:54322/flowforge?sslmode=disable

REDIS_URL=localhost:63797
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=change-me-in-production

# Docker (script container execution)
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_PYTHON_IMAGE=flowforge/runner-python:latest
DOCKER_NODE_IMAGE=flowforge/runner-nodejs:latest
DOCKER_MEMORY_MB=128
DOCKER_CPU=0.5
DOCKER_TIMEOUT_S=30
